[Unit]
Description=42nd QRF Battalion Website
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/Attendance_Tracker/42nd_Website
ExecStart=/home/ubuntu/Attendance_Tracker/venv/bin/gunicorn -w 2 -b 127.0.0.1:5000 server:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
